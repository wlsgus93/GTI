# GTI Backend 환경변수 예시
# 실 사용 시 backend/.env로 복사 후 값 채우기 (.env는 gitignore됨)

# Database
DB_URL=jdbc:postgresql://localhost:5432/gti
DB_USER=gti
DB_PASSWORD=gti

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Spring AI (Anthropic Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Steam
STEAM_API_KEY=

# Twitch (IGDB와 토큰 공유)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# YouTube
YOUTUBE_API_KEY=

# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=gti/0.1 by your-username

# OpenCritic (선택)
OPENCRITIC_API_KEY=

# Crawler Service (Google Play / SteamDB)
# 로컬 dev: http://localhost:3001 / docker: http://crawler-service:3001
CRAWLER_SERVICE_URL=http://localhost:3001

# Spring profile
SPRING_PROFILES_ACTIVE=local
